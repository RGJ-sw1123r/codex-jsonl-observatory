{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex JSONL Observatory",
  "version": "0.1.0",
  "identifier": "com.rgj.codexjsonlobservatory",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex JSONL Observatory",
        "width": 1220,
        "height": 820,
        "minWidth": 940,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
